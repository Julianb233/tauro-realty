# ==============================================================================
# LYL — Production Environment Variables
# ==============================================================================
# Copy to .env.local (local dev) or set in Vercel Dashboard (production).
# All NEXT_PUBLIC_* vars are exposed to the browser; others are server-only.
# ==============================================================================

# --- Site Configuration ---
NEXT_PUBLIC_SITE_URL=https://www.lylrealty.com

# --- Supabase (required — database & auth) ---
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (email delivery) ---
# https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=noreply.com
ADMIN_EMAIL=julian@aiacrobatics.com

# --- GoHighLevel (CRM lead sync) ---
GHL_WEBHOOK_URL=
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=

# --- Cloudflare Turnstile (bot protection) ---
# https://dash.cloudflare.com > Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Google Analytics 4 (optional) ---
# https://analytics.google.com > Admin > Data Streams > Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Sentry (optional — error tracking) ---
# https://sentry.io > Settings > Projects > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Mapbox (required — property maps) ---
# https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Cron Secret (secure cron endpoints) ---
# Generate: openssl rand -hex 32
CRON_SECRET=

# --- Upload Security ---
UPLOAD_API_KEY=

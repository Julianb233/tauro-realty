# Site URL (production domain — used for SEO, sitemaps, OpenGraph, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://www.lylrealty.com

# Supabase (required for database)
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GoHighLevel (optional, for lead sync)
GHL_WEBHOOK_URL=your-ghl-webhook-url
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply.com
ADMIN_EMAIL=julian@aiacrobatics.com

# Mapbox (required for property maps)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Cloudflare Turnstile (optional, CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Analytics 4 (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry (optional, error tracking)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Cron
CRON_SECRET=

# Upload API key (required for /api/upload and /api/agents/add endpoints)
UPLOAD_API_KEY=your-upload-api-key
